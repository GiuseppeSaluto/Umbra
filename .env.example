# MongoDB - database name ("umbra") is set in code (db/mongo.py), not in the URI
MONGO_URI=mongodb://localhost:27017

# Flask
FLASK_ENV=development

# CORS - comma-separated list of origins allowed to call /api/* from a
# browser. "*" (default) is fine for a personal/demo deployment.
CORS_ORIGINS=*

# Rate limiting - storage backend for request counters. "memory://" (default)
# is single-process only; move to a shared store (e.g. Redis) only if the app
# ever runs behind more than one worker process.
RATELIMIT_STORAGE_URI=memory://
